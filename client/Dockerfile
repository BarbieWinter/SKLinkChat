FROM node:20-alpine

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

ARG VITE_ENDPOINT=http://localhost:8000
ARG VITE_WS_ENDPOINT=ws://localhost:8000/ws
ARG VITE_GEETEST_ENABLED=false
ARG VITE_GEETEST_REGISTER_CAPTCHA_ID=
ARG VITE_GEETEST_LOGIN_CAPTCHA_ID=

ENV VITE_ENDPOINT=${VITE_ENDPOINT}
ENV VITE_WS_ENDPOINT=${VITE_WS_ENDPOINT}
ENV VITE_GEETEST_ENABLED=${VITE_GEETEST_ENABLED}
ENV VITE_GEETEST_REGISTER_CAPTCHA_ID=${VITE_GEETEST_REGISTER_CAPTCHA_ID}
ENV VITE_GEETEST_LOGIN_CAPTCHA_ID=${VITE_GEETEST_LOGIN_CAPTCHA_ID}

RUN npm run build

EXPOSE 4173

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "4173"]
